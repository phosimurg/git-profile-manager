{
  "name": "git-profile-manager",
  "version": "1.0.0",
  "description": "Git Profile Manager Application",
  "main": "./electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "cross-env BROWSER=none react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron --disable-web-security .\"",
    "electron:start": "wait-on http://localhost:3000 && electron --disable-web-security .",
    "electron:build": "npm run build && electron-builder build --mac --win",
    "electron:build:mac": "npm run build && electron-builder build --mac",
    "electron:build:win": "npm run build && electron-builder build --win",
    "electron:build:custom": "npm run build && node scripts/build.js"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^7.3.0",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "react-scripts": "5.0.1",
    "wait-on": "^9.0.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "overrides": {
    "webpack": "^5.104.1",
    "webpack-dev-server": "^4.15.2",
    "on-headers": "^1.1.0",
    "form-data": "^3.0.4",
    "tmp": "^0.2.4",
    "js-yaml": "^3.14.2",
    "glob": "^10.5.0",
    "node-forge": "^1.3.2",
    "qs": "^6.14.1",
    "tar": "^7.5.3",
    "lodash": "^4.17.23",
    "jsonpath": "^1.2.0",
    "rollup": "^2.80.0",
    "nth-check": "^2.0.1",
    "postcss": "^8.4.31",
    "serialize-javascript": "^7.0.4",
    "underscore": "^1.13.8",
    "@tootallnate/once": "^3.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.phosimurg.gitprofilemanager",
    "productName": "Git Profile Manager",
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "AHMET YILDIZ (C58CBKZPU4)",
      "type": "distribution",
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico",
      "forceCodeSigning": false
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "asar": true
  }
}
